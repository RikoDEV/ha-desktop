<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:styling="using:FluentAvalonia.Styling"
             x:Class="HaDesktop.Tray.App"
             RequestedThemeVariant="Default">

    <Application.Styles>
        <!-- PreferUserAccentColor reads the OS accent color (Windows accent, macOS accent
             preference, Linux desktop-portal accent) instead of a fixed default blue, so
             buttons/toggles/highlights match the user's actual system theme. -->
        <styling:FluentAvaloniaTheme PreferUserAccentColor="True" />
    </Application.Styles>
</Application>
