<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        xmlns:loc="using:HaDesktop.Tray.Localization"
        x:Class="HaDesktop.Tray.SettingsWindow"
        Title="{loc:Tr Settings.WindowTitle}"
        Icon="avares://HaDesktop.Tray/Assets/tray-icon.ico"
        Width="820" Height="640"
        CanResize="True"
        MinWidth="680" MinHeight="480"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur, Mica, Blur"
        WindowStartupLocation="CenterScreen">

    <!-- Same frosted-glass material as the tray flyout, so Settings doesn't look like a
         plain opaque dialog bolted onto a translucent app. -->
    <ExperimentalAcrylicBorder>
        <ExperimentalAcrylicBorder.Material>
            <ExperimentalAcrylicMaterial
                BackgroundSource="Digger"
                TintColor="{DynamicResource SolidBackgroundFillColorBase}"
                TintOpacity="0.5"
                MaterialOpacity="0.55" />
        </ExperimentalAcrylicBorder.Material>

    <Grid ColumnDefinitions="220,*">
        <Grid Grid.Column="0">
            <!-- Faded separately from the content below it — Opacity on the Border itself would
                 fade the nav text/list along with the background. -->
            <Border Background="{DynamicResource LayerFillColorDefaultBrush}" Opacity="0.6" />
            <StackPanel Spacing="4" Margin="12,20">
                <TextBlock Text="{loc:Tr Tray.Settings}" FontSize="20" FontWeight="SemiBold" Margin="8,0,8,16" />
                <ListBox Name="NavList" SelectionChanged="OnNavSelectionChanged" Background="Transparent">
                    <ListBoxItem Content="{loc:Tr Nav.Connection}" />
                    <ListBoxItem Content="{loc:Tr Nav.Tiles}" />
                    <ListBoxItem Content="{loc:Tr Nav.Appearance}" />
                    <ListBoxItem Content="{loc:Tr Nav.Sensors}" />
                    <ListBoxItem Content="{loc:Tr Nav.System}" />
                    <ListBoxItem Content="{loc:Tr Nav.Notifications}" />
                    <ListBoxItem Content="{loc:Tr Nav.About}" />
                </ListBox>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Column="1">
            <Grid Margin="28,24,28,24">
                <!-- Connection: dynamic (signed-in vs signed-out), so it's a plain card rather than a SettingsExpander. -->
                <StackPanel Name="ConnectionPage" Spacing="4">
                    <TextBlock Text="{loc:Tr Connection.Header}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16" />
                    <Border CornerRadius="8" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="16">
                        <StackPanel Spacing="8">
                            <StackPanel Name="ConnectedPanel" Spacing="10" IsVisible="False">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="10" Height="10" CornerRadius="5" Background="MediumSeaGreen" VerticalAlignment="Center" />
                                    <TextBlock Name="ConnectedUrlText" VerticalAlignment="Center" FontSize="13" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                    <Button Name="SwitchInstanceButton" Content="{loc:Tr Connection.SwitchInstance}" Click="OnSwitchInstanceClicked" />
                                    <Button Name="SignOutButton" Content="{loc:Tr Connection.SignOut}" Click="OnSignOutClicked" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Name="SignInPanel" Spacing="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{loc:Tr Connection.UrlLabel}" FontSize="12" Opacity="0.7" />
                                    <TextBox Name="BaseUrlBox" Watermark="http://homeassistant.local:8123" />
                                </StackPanel>

                                <TextBlock Name="StatusText" FontSize="12" TextWrapping="Wrap" />

                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                    <Button Name="CancelSwitchButton" Content="{loc:Tr Connection.Cancel}" Click="OnCancelSwitchClicked" IsVisible="False" />
                                    <Button Name="LoginButton" Content="{loc:Tr Connection.SignIn}" Click="OnLoginClicked" Classes="accent" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Name="InstanceInfoCard" CornerRadius="8" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="16"
                            Margin="0,12,0,0" IsVisible="False">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{loc:Tr Connection.InstanceHeader}" FontSize="14" FontWeight="SemiBold" />
                            <StackPanel Name="InstanceInfoPanel" Spacing="6" />
                        </StackPanel>
                    </Border>

                    <Border Name="UpdatesCard" CornerRadius="8" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="16"
                            Margin="0,12,0,0" IsVisible="False">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{loc:Tr Connection.UpdatesHeader}" FontSize="14" FontWeight="SemiBold" />
                            <StackPanel Name="UpdatesPanel" Spacing="6" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Name="TilesPage" Spacing="4" IsVisible="False">
                    <TextBlock Text="{loc:Tr Tiles.Header}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16" />

                    <ui:SettingsExpander Header="{loc:Tr Tiles.QuickTilesHeader}"
                                          Description="{loc:Tr Tiles.QuickTilesDescription}"
                                          IsExpanded="True">
                        <ui:SettingsExpander.Footer>
                            <Button Name="ChooseTilesButton" Content="{loc:Tr Tiles.ChooseTiles}" Click="OnChooseTilesClicked" />
                        </ui:SettingsExpander.Footer>
                        <ui:SettingsExpander.Items>
                            <StackPanel Name="SelectedTilesPanel" Spacing="6" Margin="16,8" />
                        </ui:SettingsExpander.Items>
                    </ui:SettingsExpander>

                    <ui:SettingsExpander Header="{loc:Tr Tiles.WeatherHeader}"
                                          Description="{loc:Tr Tiles.WeatherDescription}"
                                          IsExpanded="True" Margin="0,8,0,0">
                        <ui:SettingsExpander.Footer>
                            <ToggleSwitch Name="WeatherEnabledCheckBox" OnContent="" OffContent="" Click="OnWeatherEnabledChanged" />
                        </ui:SettingsExpander.Footer>
                        <ui:SettingsExpander.Items>
                            <StackPanel Spacing="4" Margin="16,8">
                                <TextBlock Text="{loc:Tr Tiles.WeatherEntityLabel}" FontSize="12" Opacity="0.7" />
                                <ComboBox Name="WeatherEntityBox" Width="280" SelectionChanged="OnWeatherEntityChanged" />
                            </StackPanel>
                            <Grid ColumnDefinitions="*,Auto" Margin="16,8">
                                <TextBlock Grid.Column="0" Text="{loc:Tr Tiles.ConditionBackground}" FontSize="13" VerticalAlignment="Center" />
                                <ToggleSwitch Grid.Column="1" Name="WeatherBackgroundCheckBox" OnContent="" OffContent="" Click="OnWeatherOptionChanged" VerticalAlignment="Center" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Margin="16,8">
                                <TextBlock Grid.Column="0" Text="{loc:Tr Tiles.ShowWindHumidity}" FontSize="13" VerticalAlignment="Center" />
                                <ToggleSwitch Grid.Column="1" Name="WeatherWindHumidityCheckBox" OnContent="" OffContent="" Click="OnWeatherOptionChanged" VerticalAlignment="Center" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Margin="16,8">
                                <TextBlock Grid.Column="0" Text="{loc:Tr Tiles.ShowForecast}" FontSize="13" VerticalAlignment="Center" />
                                <ToggleSwitch Grid.Column="1" Name="WeatherForecastCheckBox" OnContent="" OffContent="" Click="OnWeatherOptionChanged" VerticalAlignment="Center" />
                            </Grid>
                            <StackPanel Spacing="4" Margin="16,8">
                                <TextBlock Text="{loc:Tr Tiles.ForecastDaysLabel}" FontSize="12" Opacity="0.7" />
                                <ComboBox Name="WeatherForecastDaysBox" Width="120" SelectionChanged="OnWeatherForecastDaysChanged">
                                    <ComboBoxItem Content="{loc:Tr Tiles.ForecastDays3}" Tag="3" />
                                    <ComboBoxItem Content="{loc:Tr Tiles.ForecastDays4}" Tag="4" />
                                    <ComboBoxItem Content="{loc:Tr Tiles.ForecastDays5}" Tag="5" />
                                    <ComboBoxItem Content="{loc:Tr Tiles.ForecastDays7}" Tag="7" />
                                </ComboBox>
                            </StackPanel>
                        </ui:SettingsExpander.Items>
                    </ui:SettingsExpander>

                    <ui:SettingsExpander Header="{loc:Tr Tiles.MediaHeader}"
                                          Description="{loc:Tr Tiles.MediaDescription}"
                                          IsExpanded="True" Margin="0,8,0,0">
                        <ui:SettingsExpander.Footer>
                            <ToggleSwitch Name="MediaPlayerEnabledCheckBox" OnContent="" OffContent="" Click="OnMediaPlayerEnabledChanged" />
                        </ui:SettingsExpander.Footer>
                        <ui:SettingsExpander.Items>
                            <StackPanel Spacing="4" Margin="16,8">
                                <TextBlock Text="{loc:Tr Tiles.MediaEntityLabel}" FontSize="12" Opacity="0.7" />
                                <ComboBox Name="MediaPlayerEntityBox" Width="280" SelectionChanged="OnMediaPlayerEntityChanged" />
                            </StackPanel>
                            <Grid ColumnDefinitions="*,Auto" Margin="16,8">
                                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Tr Tiles.MediaBackgroundTitle}" FontSize="13" />
                                    <TextBlock Text="{loc:Tr Tiles.MediaBackgroundDescription}" FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" Name="MediaPlayerBackgroundCheckBox" OnContent="" OffContent="" Click="OnMediaPlayerBackgroundChanged" VerticalAlignment="Center" />
                            </Grid>
                        </ui:SettingsExpander.Items>
                    </ui:SettingsExpander>
                </StackPanel>

                <StackPanel Name="AppearancePage" Spacing="4" IsVisible="False">
                    <TextBlock Text="{loc:Tr Appearance.Header}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16" />

                    <ui:SettingsExpander Header="{loc:Tr Appearance.TilesHeader}"
                                          Description="{loc:Tr Appearance.TilesDescription}"
                                          IsExpanded="True">
                        <ui:SettingsExpander.Items>
                            <StackPanel Spacing="4" Margin="16,8">
                                <TextBlock Text="{loc:Tr Appearance.TileShape}" FontSize="12" Opacity="0.7" />
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <RadioButton Name="ShapeRoundedRadio" GroupName="TileShape" Content="{loc:Tr Appearance.Rounded}" Checked="OnTileShapeChanged" />
                                    <RadioButton Name="ShapeSquareRadio" GroupName="TileShape" Content="{loc:Tr Appearance.Square}" Checked="OnTileShapeChanged" />
                                    <RadioButton Name="ShapePillRadio" GroupName="TileShape" Content="{loc:Tr Appearance.Pill}" Checked="OnTileShapeChanged" />
                                </StackPanel>
                            </StackPanel>
                        </ui:SettingsExpander.Items>
                    </ui:SettingsExpander>
                </StackPanel>

                <StackPanel Name="SensorsPage" Spacing="4" IsVisible="False">
                    <TextBlock Text="{loc:Tr Sensors.Header}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16" />

                    <ui:SettingsExpander Header="{loc:Tr Sensors.ShareHeader}"
                                          Description="{loc:Tr Sensors.ShareDescription}"
                                          IsExpanded="True">
                        <ui:SettingsExpander.Footer>
                            <ToggleSwitch Name="SensorSharingMasterCheckBox" OnContent="" OffContent="" Click="OnSensorSharingMasterChanged" />
                        </ui:SettingsExpander.Footer>
                        <ui:SettingsExpander.Items>
                            <StackPanel Spacing="12" Margin="16,8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{loc:Tr Sensors.DeviceName}" FontSize="12" Opacity="0.7" />
                                    <TextBox Name="DeviceNameBox" Watermark="HA Desktop" LostFocus="OnDeviceNameLostFocus" />
                                    <TextBlock Name="DeviceSlugPreview" FontSize="11" Opacity="0.6" />
                                </StackPanel>

                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{loc:Tr Sensors.CpuUsage}" VerticalAlignment="Center" />
                                        <ToggleSwitch Grid.Column="1" Name="ShareCpuCheckBox" OnContent="" OffContent="" Click="OnSensorToggleChanged" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{loc:Tr Sensors.MemoryUsage}" VerticalAlignment="Center" />
                                        <ToggleSwitch Grid.Column="1" Name="ShareMemoryCheckBox" OnContent="" OffContent="" Click="OnSensorToggleChanged" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{loc:Tr Sensors.Battery}" VerticalAlignment="Center" />
                                        <ToggleSwitch Grid.Column="1" Name="ShareBatteryCheckBox" OnContent="" OffContent="" Click="OnSensorToggleChanged" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{loc:Tr Sensors.DiskUsage}" VerticalAlignment="Center" />
                                        <ToggleSwitch Grid.Column="1" Name="ShareDiskCheckBox" OnContent="" OffContent="" Click="OnSensorToggleChanged" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{loc:Tr Sensors.Uptime}" VerticalAlignment="Center" />
                                        <ToggleSwitch Grid.Column="1" Name="ShareUptimeCheckBox" OnContent="" OffContent="" Click="OnSensorToggleChanged" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{loc:Tr Sensors.ActiveWindow}" VerticalAlignment="Center" />
                                        <ToggleSwitch Grid.Column="1" Name="ShareActiveWindowCheckBox" OnContent="" OffContent="" Click="OnSensorToggleChanged" />
                                    </Grid>
                                    <TextBlock Text="{loc:Tr Sensors.ActiveWindowNote}"
                                                FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{loc:Tr Sensors.Gpu}" VerticalAlignment="Center" />
                                        <ToggleSwitch Grid.Column="1" Name="ShareGpuCheckBox" OnContent="" OffContent="" Click="OnSensorToggleChanged" />
                                    </Grid>
                                    <TextBlock Text="{loc:Tr Sensors.GpuNote}"
                                                FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{loc:Tr Sensors.Network}" VerticalAlignment="Center" />
                                        <ToggleSwitch Grid.Column="1" Name="ShareNetworkCheckBox" OnContent="" OffContent="" Click="OnSensorToggleChanged" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </ui:SettingsExpander.Items>
                    </ui:SettingsExpander>
                </StackPanel>

                <StackPanel Name="SystemPage" Spacing="4" IsVisible="False">
                    <TextBlock Text="{loc:Tr System.Header}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16" />

                    <ui:SettingsExpander Header="{loc:Tr System.StartupHeader}" Description="{loc:Tr System.StartupDescription}">
                        <ui:SettingsExpander.Footer>
                            <ToggleSwitch Name="AutostartCheckBox" OnContent="" OffContent="" Click="OnAutostartChanged" />
                        </ui:SettingsExpander.Footer>
                    </ui:SettingsExpander>

                    <ui:SettingsExpander Header="{loc:Tr Language.Header}"
                                          Description="{loc:Tr Language.Description}"
                                          IsExpanded="True" Margin="0,8,0,0">
                        <ui:SettingsExpander.Items>
                            <StackPanel Spacing="4" Margin="16,8">
                                <TextBlock Text="{loc:Tr Language.Label}" FontSize="12" Opacity="0.7" />
                                <ComboBox Name="LanguageBox" Width="220" SelectionChanged="OnLanguageChanged">
                                    <ComboBoxItem Content="{loc:Tr Language.NameEnglish}" Tag="English" />
                                    <ComboBoxItem Content="{loc:Tr Language.NamePolish}" Tag="Polish" />
                                    <ComboBoxItem Content="{loc:Tr Language.NameGerman}" Tag="German" />
                                    <ComboBoxItem Content="{loc:Tr Language.NameFrench}" Tag="French" />
                                    <ComboBoxItem Content="{loc:Tr Language.NameRussian}" Tag="Russian" />
                                </ComboBox>
                            </StackPanel>
                        </ui:SettingsExpander.Items>
                    </ui:SettingsExpander>
                </StackPanel>

                <StackPanel Name="NotificationsPage" Spacing="4" IsVisible="False">
                    <TextBlock Text="{loc:Tr Notifications.Header}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16" />

                    <ui:SettingsExpander Header="{loc:Tr Notifications.PushHeader}"
                                          Description="{loc:Tr Notifications.PushDescription}"
                                          IsExpanded="True">
                        <ui:SettingsExpander.Footer>
                            <ToggleSwitch Name="NotificationsCheckBox" OnContent="" OffContent="" Click="OnNotificationsChanged" />
                        </ui:SettingsExpander.Footer>
                        <ui:SettingsExpander.Items>
                            <StackPanel Spacing="8" Margin="16,8">
                                <TextBlock Name="NotifyServiceText" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                                <Button Name="TestNotificationButton" Content="{loc:Tr Notifications.SendTest}" Click="OnTestNotificationClicked" HorizontalAlignment="Left" />
                            </StackPanel>
                        </ui:SettingsExpander.Items>
                    </ui:SettingsExpander>
                </StackPanel>

                <StackPanel Name="AboutPage" Spacing="4" IsVisible="False">
                    <TextBlock Text="{loc:Tr About.Header}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16" />

                    <Border CornerRadius="8" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="20">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Width="40" Height="40" CornerRadius="8" Background="{DynamicResource AccentFillColorDefaultBrush}">
                                    <PathIcon Name="AboutAppIcon" Width="20" Height="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center" Spacing="0">
                                    <TextBlock Text="HA Desktop" FontSize="16" FontWeight="SemiBold" />
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Text="{loc:Tr About.Description}"
                                       TextWrapping="Wrap" FontSize="13" Opacity="0.85" />

                            <StackPanel Spacing="4">
                                <TextBlock Text="{loc:Tr About.Version}" FontSize="12" Opacity="0.7" />
                                <TextBlock Name="AboutVersionText" FontSize="13" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="{loc:Tr About.Author}" FontSize="12" Opacity="0.7" />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="RikoDEV —" VerticalAlignment="Center" FontSize="13" />
                                    <Button Name="AuthorLinkButton" Content="https://riko.dev" Click="OnAuthorLinkClicked"
                                            Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                            Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="{loc:Tr About.GitHub}" FontSize="12" Opacity="0.7" />
                                <Button Name="GitHubLinkButton" Content="https://github.com/RikoDEV/ha-desktop" Click="OnGitHubLinkClicked"
                                        Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                        Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="{loc:Tr About.BuiltWith}" FontSize="12" Opacity="0.7" />
                                <TextBlock Text="Avalonia UI + FluentAvaloniaUI · .NET" FontSize="13" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
    </ExperimentalAcrylicBorder>
</Window>
