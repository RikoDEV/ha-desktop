<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HaDesktop.Tray.EntityPickerWindow"
        Title="HA Desktop — Choose Tiles"
        Width="380" Height="480"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16" >
        <TextBlock Grid.Row="0" Text="Choose Tiles" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBox Name="SearchBox" Watermark="Search entities…" Width="220" TextChanged="OnSearchChanged" />
            <ComboBox Name="DomainFilterBox" Width="120" SelectionChanged="OnDomainFilterChanged">
                <ComboBoxItem Content="All types" Tag="" />
                <ComboBoxItem Content="Lights" Tag="light" />
                <ComboBoxItem Content="Switches" Tag="switch" />
                <ComboBoxItem Content="Covers" Tag="cover" />
                <ComboBoxItem Content="Sensors" Tag="sensor" />
                <ComboBoxItem Content="Cameras" Tag="camera" />
            </ComboBox>
        </StackPanel>

        <ScrollViewer Grid.Row="2">
            <StackPanel Name="RowsPanel" Spacing="2" />
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock Name="StatusText" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
            <Button Name="SaveButton" Content="Save" Click="OnSaveClicked" Classes="accent" />
        </StackPanel>
    </Grid>
</Window>
